{% extends "base.html" %}
{% from "_macros.html" import render_field %}
{% block title %}{{ titre }} — GBV{% endblock %}
{% block page_title %}{{ titre }}{% endblock %}
{% block content %}
<div class="row justify-content-center"><div class="col-lg-6">
  <div class="form-card">
    <h5 class="mb-4"><i class="bi bi-droplet me-2 text-success"></i>{{ titre }}</h5>
    <form method="post">
      {{ form.hidden_tag() }}
      {{ render_field(form.type_eaux, placeholder="Ex: Boues primaires, Eaux grises") }}
      <div class="row">
        <div class="col-6">{{ render_field(form.volumetrique, placeholder="Volume en m³") }}</div>
        <div class="col-6">{{ render_field(form.niveau_contamination) }}</div>
      </div>
      {{ render_field(form.fosse_id) }}
      <hr>
      <div class="d-flex gap-2">
        {{ form.submit(class="btn btn-primary") }}
        <a href="{{ url_for('eaux.index') }}" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </form>
  </div>
</div></div>
{% endblock %}
